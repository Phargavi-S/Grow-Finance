# Backend environment variables (copy to .env and fill values)
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/billingDB
SESSION_SECRET=replace_with_secure_secret

# Email (Gmail app password recommended)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_ENABLED=true

# Company info used in PDFs and email
COMPANY_NAME=Your Company
COMPANY_ADDRESS=123 Business Rd
COMPANY_EMAIL=billing@yourcompany.com
COMPANY_PHONE=+1-555-000-0000

# Currency symbol shown in PDFs/emails
CURRENCY_SYMBOL=₹
